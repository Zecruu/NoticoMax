{
  "name": "notico-max",
  "version": "2.5.7",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -p 5467",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently \"next dev -p 5467\" \"wait-on http://localhost:5467 && NODE_ENV=development electron .\"",
    "electron:build": "electron-builder --win --publish never",
    "electron:build:mac": "electron-builder --mac --publish never && node scripts/notarize-dmg.js",
    "cap:sync": "npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "cap:dev:ios": "npx cap run ios --livereload --external",
    "cap:dev:android": "npx cap run android --livereload --external",
    "ios:build": "node scripts/build-ios.js",
    "ios:build:upload": "node scripts/build-ios.js --upload",
    "postinstall": "patch-package"
  },
  "build": {
    "appId": "com.noticomax.app",
    "productName": "Notico Max",
    "directories": {
      "output": "dist-electron"
    },
    "protocols": [
      {
        "name": "NoticoMax Protocol",
        "schemes": [
          "noticomax"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Zecruu",
        "repo": "NoticoMax"
      }
    ],
    "files": [
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/logo.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "Notico-Max-${version}-${arch}-mac.${ext}",
      "icon": "public/icon-mac-1024.png",
      "category": "public.app-category.productivity",
      "notarize": true,
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "artifactName": "Notico-Max-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/logo.ico",
      "uninstallerIcon": "public/logo.ico",
      "artifactName": "Notico-Max-Setup-${version}.${ext}"
    }
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/local-notifications": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@capawesome/capacitor-badge": "^8.0.0",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@revenuecat/purchases-capacitor": "^13.0.1",
    "@revenuecat/purchases-capacitor-ui": "^13.0.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "capacitor-native-biometric": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.4.0",
    "electron-updater": "^6.7.3",
    "highlight.js": "^11.11.1",
    "ical.js": "^2.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.563.0",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@tailwindcss/postcss": "^4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "electron": "^40.4.0",
    "electron-builder": "^26.7.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "patch-package": "^8.0.1",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "wait-on": "^9.0.3"
  }
}
